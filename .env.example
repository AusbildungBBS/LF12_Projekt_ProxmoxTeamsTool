# ── Azure AD / Microsoft Entra ID App Registration ────────────────────────────
# Available to both frontend (VITE_ prefix) and the Bridge.
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here

# ── Bridge ────────────────────────────────────────────────────────────────────
# Mirror of the values above (the bridge reads either form).
AZURE_CLIENT_ID=your-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Expected audience claim in inbound access tokens.
# Defaults to api://<AZURE_CLIENT_ID> if not set — set explicitly if you
# configured a custom Application ID URI in Entra.
# API_AUDIENCE=api://your-client-id-here

PORT=3001

# How the bridge derives roles + classes for an authenticated user.
#   standard — App Roles (Proxmox.Admin/Teacher/Student) + M365-Group memberships
#   edu      — Microsoft Education Graph (/education/me, /education/me/classes)
#   auto     — probes /education/me on first request per user, falls back to
#              standard on 403/404. Recommended default.
AUTH_MODE=auto

# ── Proxmox (placeholder for later — Bridge does not use these yet) ───────────
# PROXMOX_URL=https://proxmox.local:8006
# PROXMOX_TOKEN_ID=user@pve!tokenname
# PROXMOX_TOKEN_SECRET=

# ── Cloudflare Tunnel (optional, for prod deployment of the Bridge) ───────────
# Generated in the Cloudflare Zero Trust dashboard. See docker-compose.yml.
# CF_TUNNEL_TOKEN=
