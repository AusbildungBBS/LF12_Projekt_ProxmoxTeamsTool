{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.20/MicrosoftTeams.schema.json",
  "manifestVersion": "1.20",
  "version": "0.1.2",
  "id": "{{AZURE_CLIENT_ID}}",
  "developer": {
    "name": "LF12 Projekt Team",
    "websiteUrl": "https://{{FRONTEND_HOST}}",
    "privacyUrl": "https://{{FRONTEND_HOST}}/privacy",
    "termsOfUseUrl": "https://{{FRONTEND_HOST}}/terms"
  },
  "name": {
    "short": "Proxmox Teams Tool",
    "full": "Proxmox-Verwaltung für Microsoft Teams"
  },
  "description": {
    "short": "Proxmox VE direkt aus Microsoft Teams verwalten",
    "full": "Microsoft-Teams-Tab zum Verwalten von Proxmox-VMs aus Vorlagen. Lehrer weisen Vorlagen Klassen zu, Schüler erstellen daraus eigene VMs und steuern sie (Start, Stopp, Konsole)."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#6264a7",
  "staticTabs": [
    {
      "entityId": "dashboard",
      "name": "Proxmox",
      "contentUrl": "https://{{FRONTEND_HOST}}/",
      "websiteUrl": "https://{{FRONTEND_HOST}}/",
      "scopes": ["personal"]
    },
    {
      "entityId": "templates",
      "name": "Vorlagen",
      "contentUrl": "https://{{FRONTEND_HOST}}/templates",
      "websiteUrl": "https://{{FRONTEND_HOST}}/templates",
      "scopes": ["personal"]
    },
    {
      "entityId": "vms",
      "name": "Meine VMs",
      "contentUrl": "https://{{FRONTEND_HOST}}/my-vms",
      "websiteUrl": "https://{{FRONTEND_HOST}}/my-vms",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["{{FRONTEND_HOST}}"],
  "webApplicationInfo": {
    "id": "{{AZURE_CLIENT_ID}}",
    "resource": "{{AZURE_APP_ID_URI}}"
  }
}
